---
---

<header class="w-full px-2 mt-4 md:mt-12 relative z-10 select-none pointer-events-none">
  <h1 class="font-oswald font-semibold text-giant leading-[0.75] tracking-tighter text-center uppercase stretch-text flex flex-col md:block items-center">
    <span class="block md:inline opacity-0 translate-y-24" id="word1">Fullstack</span>
    <span class="block md:inline md:-ml-8 opacity-0 translate-y-24" id="word2">Developer</span>
  </h1>
</header>

<!-- Main Hero Content Grid -->
<section class="flex-grow w-full px-4 md:px-8 mt-12 md:mt-0 relative z-20">
  <div class="grid grid-cols-1 md:grid-cols-12 gap-8 md:gap-4 h-full">

    <!-- Left Column: Skills List -->
    <div class="col-span-1 md:col-span-3 flex flex-col justify-end pb-8 md:pb-20 order-2 md:order-1 opacity-0 animate-fade-in-up delay-300">
      <ul class="text-xs md:text-sm leading-relaxed space-y-2">
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" /></svg>
          FRONTEND DEVELOPMENT
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2" /></svg>
          BACKEND DEVELOPMENT
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" /></svg>
          UI/UX DESIGN
        </li>
        <li class="flex items-center gap-2">
          <svg class="w-4 h-4 text-neutral-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2 1 3 3 3h10c2 0 3-1 3-3V7c0-2-1-3-3-3H7C5 4 4 5 4 7zm0 5h16M9 4v16" /></svg>
          DATABASE MANAGEMENT
        </li>
      </ul>
    </div>

    <!-- Center Column: Photo -->
    <div class="col-span-1 md:col-span-6 order-1 md:order-2 flex flex-col items-center relative group opacity-0 animate-fade-in-up delay-200">
      <!-- Decorative ring -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] border border-neutral-400/30 rounded-full animate-spin pointer-events-none z-0" style="animation-duration: 15s;"></div>

      <div class="relative w-full max-w-md aspect-[3/4] overflow-hidden grayscale group-hover:grayscale-0 transition-all duration-700 ease-out z-10" id="tilt-card">
        <img src="/images/me.jpeg" alt="John David A. Calimpong" class="w-full h-full object-cover scale-105 group-hover:scale-100 transition-transform duration-700" />
        <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors duration-500"></div>

        <!-- Overlay -->
        <div class="absolute bottom-4 left-0 w-full text-center opacity-0 group-hover:opacity-100 transition-opacity duration-500">
          <span class="bg-white/90 px-3 py-1 text-xs font-semibold tracking-tight text-black backdrop-blur-sm">
            AVAILABLE FOR HIRE
          </span>
        </div>
      </div>
    </div>

    <!-- Right Column: Latest Project -->
    <div class="col-span-1 md:col-span-3 flex flex-col justify-end items-start md:items-end pb-8 md:pb-20 order-3 text-left md:text-right opacity-0 animate-fade-in-up delay-400">
      <span class="text-xs md:text-sm text-neutral-500 mb-2">LATEST PROJECT</span>
      <a href="#projects" class="font-oswald text-5xl md:text-6xl uppercase leading-none tracking-tight hover:italic stretch-text">
        CAPSTONE<br />CONNECT
      </a>
      <div class="mt-4 flex gap-2">
        <span class="px-2 py-1 border border-black/10 text-[10px] uppercase">JavaScript</span>
        <span class="px-2 py-1 border border-black/10 text-[10px] uppercase">CSS</span>
      </div>
    </div>

  </div>
</section>

<!-- Central Statement -->
<section class="w-full px-4 md:px-0 max-w-2xl mx-auto text-center mt-16 md:mt-24 mb-8 relative z-20 opacity-0 animate-fade-in-up delay-500">
  <p class="text-sm md:text-base leading-relaxed font-medium uppercase text-neutral-800">
    An aspiring developer who focuses on delivering good<br class="hidden md:block" />
    digital experiences. Blending UX/UI design ideas with<br class="hidden md:block" />
    frontend development skills to create engaging interfaces.
  </p>
</section>

<!-- Tech Stack -->
<div class="w-full border-t border-b border-neutral-300 relative z-20 opacity-0 animate-fade-in-up delay-600">
  <div class="flex items-stretch">
    <!-- Left: TECH STACK label (static) -->
    <div class="shrink-0 flex items-center gap-3 px-4 md:px-8 py-5 border-r border-neutral-300">
      <span class="text-xs md:text-sm uppercase tracking-[0.2em] text-brand-black font-bold whitespace-nowrap">TECH STACK</span>
      <span class="inline-block w-8 h-px bg-neutral-400"></span>
    </div>

    <!-- Center: scrolling marquee -->
    <div class="flex-1 overflow-hidden py-5">
      <div class="flex items-center whitespace-nowrap animate-marquee">
        <span class="flex items-center gap-8 mx-8 text-xs md:text-sm uppercase tracking-[0.15em] text-neutral-500">
          <span>HTML5</span><span>CSS</span><span>JavaScript</span><span>ReactJS</span><span>Java</span><span>Tailwind</span><span>Astro</span><span>Figma</span><span>GitHub</span><span>WordPress</span><span>Canva</span>
        </span>
        <span class="flex items-center gap-8 mx-8 text-xs md:text-sm uppercase tracking-[0.15em] text-neutral-500">
          <span>HTML5</span><span>CSS</span><span>JavaScript</span><span>ReactJS</span><span>Java</span><span>Tailwind</span><span>Astro</span><span>Figma</span><span>GitHub</span><span>WordPress</span><span>Canva</span>
        </span>
      </div>
    </div>

    <!-- Right: TECH STACK label (static) -->
    <div class="shrink-0 hidden md:flex items-center gap-3 px-4 md:px-8 py-5 border-l border-neutral-300">
      <span class="inline-block w-8 h-px bg-neutral-400"></span>
      <span class="text-xs md:text-sm uppercase tracking-[0.2em] text-brand-black font-bold whitespace-nowrap">TECH STACK</span>
    </div>
  </div>
</div>

<script>
  // Hero word animation
  document.addEventListener('DOMContentLoaded', () => {
    ['word1', 'word2'].forEach((id, i) => {
      const el = document.getElementById(id);
      if (!el) return;
      setTimeout(() => {
        el.style.transition = 'all 1s cubic-bezier(0.16, 1, 0.3, 1)';
        el.style.opacity = '1';
        el.style.transform = 'translateY(0)';
      }, 100 + i * 150);
    });
  });

  // 3D tilt effect
  const card = document.getElementById('tilt-card');
  if (card && window.innerWidth >= 768) {
    document.addEventListener('mousemove', (e) => {
      const xAxis = (window.innerWidth / 2 - e.pageX) / 25;
      const yAxis = (window.innerHeight / 2 - e.pageY) / 25;
      card.style.transform = `rotateY(${xAxis}deg) rotateX(${yAxis}deg)`;
    });
    document.addEventListener('mouseleave', () => {
      card.style.transform = 'rotateY(0deg) rotateX(0deg)';
    });
  }
</script>
