<section id="about" class="w-full max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- About Me -->
    <div class="border border-neutral-300 dark:border-neutral-700 p-8 md:p-10 relative group hover:border-black dark:hover:border-white transition-all duration-300 hover:shadow-[6px_6px_0px_0px_rgba(10,10,10,0.85)] dark:hover:shadow-[6px_6px_0px_0px_rgba(230,228,221,0.85)]">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 absolute -top-[0.45rem] left-6 bg-brand-bg dark:bg-brand-black px-2">[01] About</span>
      <h2 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-6">About Me</h2>
      <p class="text-sm md:text-base leading-relaxed text-neutral-700 dark:text-neutral-300 mb-6">
        An aspiring developer who focuses on delivering good digital experiences.
        Blending UX/UI design ideas with frontend development skills in HTML, CSS,
        and JavaScript. I am actively seeking opportunities to apply my technical
        expertise and passion for growth.
      </p>

      <div>
        <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-3">[LET'S CONNECT]</span>
        <div class="flex gap-4 text-sm underline decoration-1 underline-offset-2">
          <a href="#" onclick="event.preventDefault(); window.openLinkedInModal && window.openLinkedInModal();" class="hover:text-neutral-500 transition-colors">LinkedIn</a>
          <a href="https://github.com/calimps115646" target="_blank" rel="noopener noreferrer" class="hover:text-neutral-500 transition-colors">GitHub</a>
        </div>
      </div>
    </div>

    <!-- Education -->
    <div class="border border-neutral-300 dark:border-neutral-700 p-8 md:p-10 relative group hover:border-black dark:hover:border-white transition-all duration-300 hover:shadow-[6px_6px_0px_0px_rgba(10,10,10,0.85)] dark:hover:shadow-[6px_6px_0px_0px_rgba(230,228,221,0.85)]">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 absolute -top-[0.45rem] left-6 bg-brand-bg dark:bg-brand-black px-2">[02] Education</span>
      <h2 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-6">Education</h2>

      <div class="space-y-6">
        <!-- Current -->
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 bg-black dark:bg-brand-bg rounded-full"></div>
            <div class="w-px flex-1 bg-neutral-300 dark:bg-neutral-700 mt-1"></div>
          </div>
          <div>
            <h3 class="font-semibold text-sm md:text-base">BS Information Technology</h3>
            <p class="text-xs md:text-sm text-neutral-500">Cebu Institute of Technology - University</p>
            <span class="text-[10px] uppercase tracking-wider text-neutral-400 mt-1 inline-block">Currently Enrolled</span>
          </div>
        </div>

        <!-- Past -->
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 border-2 border-neutral-400 dark:border-neutral-500 rounded-full"></div>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <h3 class="font-semibold text-sm md:text-base">Senior High School - STEM</h3>
              <span class="text-[10px] border border-neutral-300 dark:border-neutral-600 px-2 py-0.5">2022</span>
            </div>
            <p class="text-xs md:text-sm text-neutral-500">Cebu Institute of Technology - University</p>
          </div>
        </div>
      </div>
    </div>

  </div>
</section>
