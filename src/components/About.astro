---
---

<section id="about" class="w-full max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

    <!-- About Me -->
    <div class="border border-neutral-300 p-8 md:p-10 relative group hover:border-black transition-colors duration-300">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 absolute -top-3 left-6 bg-brand-bg px-2">[01] About</span>
      <h2 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-6">About Me</h2>
      <p class="text-sm md:text-base leading-relaxed text-neutral-700">
        An aspiring developer who focuses on delivering good digital experiences.
        Blending UX/UI design ideas with frontend development skills in HTML, CSS,
        and JavaScript. I am actively seeking opportunities to apply my technical
        expertise and passion for growth.
      </p>
      <div class="mt-6 flex gap-3">
        <a href="mailto:johndavid.calimpong@gmail.com" class="text-xs uppercase tracking-wider underline underline-offset-4 hover:text-neutral-500 transition-colors">
          Get in touch
        </a>
        <a href="https://drive.google.com/file/d/1gOuJgk-U2qMsR-nEdtOxHWzBdDydntI-/view?usp=sharing" target="_blank" rel="noopener noreferrer" class="text-xs uppercase tracking-wider underline underline-offset-4 hover:text-neutral-500 transition-colors">
          View Resume
        </a>
      </div>
    </div>

    <!-- Education -->
    <div class="border border-neutral-300 p-8 md:p-10 relative group hover:border-black transition-colors duration-300">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 absolute -top-3 left-6 bg-brand-bg px-2">[02] Education</span>
      <h2 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-6">Education</h2>

      <div class="space-y-6">
        <!-- Current -->
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 bg-black rounded-full"></div>
            <div class="w-px flex-1 bg-neutral-300 mt-1"></div>
          </div>
          <div>
            <h3 class="font-semibold text-sm md:text-base">BS Information Technology</h3>
            <p class="text-xs md:text-sm text-neutral-500">Cebu Institute of Technology - University</p>
            <span class="text-[10px] uppercase tracking-wider text-neutral-400 mt-1 inline-block">Currently Enrolled</span>
          </div>
        </div>

        <!-- Past -->
        <div class="flex gap-4">
          <div class="flex flex-col items-center">
            <div class="w-3 h-3 border-2 border-neutral-400 rounded-full"></div>
          </div>
          <div>
            <div class="flex items-center gap-3">
              <h3 class="font-semibold text-sm md:text-base">Senior High School - STEM</h3>
              <span class="text-[10px] border border-neutral-300 px-2 py-0.5">2022</span>
            </div>
            <p class="text-xs md:text-sm text-neutral-500">Cebu Institute of Technology - University</p>
          </div>
        </div>
      </div>
    </div>

  </div>

  <!-- Skills -->
  <div class="mt-8 border border-neutral-300 p-8 md:p-10 relative group hover:border-black transition-colors duration-300">
    <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 absolute -top-3 left-6 bg-brand-bg px-2">[03] Skills</span>
    <h2 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-6">Skills</h2>
    <div class="flex flex-wrap gap-3">
      {["HTML5", "CSS", "JavaScript", "ReactJS", "Figma", "Canva", "Java", "GitHub", "Microsoft Office", "WordPress", "ClickUp"].map((skill) => (
        <span class="px-4 py-2 border border-neutral-300 text-xs md:text-sm uppercase tracking-wider hover:bg-black hover:text-brand-bg transition-colors duration-200 cursor-crosshair">
          {skill}
        </span>
      ))}
    </div>
  </div>
</section>
