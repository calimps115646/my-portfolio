---
---

<footer id="contact" class="w-full">
  <!-- Contact Section -->
  <div class="py-16 md:py-24">
    <div class="max-w-6xl mx-auto px-4 md:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-12 md:gap-16">

        <!-- Left: Info -->
        <div>
          <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-4">[04] Contact</span>
          <h2 class="font-oswald text-4xl md:text-5xl uppercase tracking-tight mb-6">LET'S TALK</h2>

          <h3 class="font-semibold text-base md:text-lg mb-3">Have a project in mind?</h3>
          <p class="text-sm text-neutral-600 dark:text-neutral-400 leading-relaxed mb-10">
            I'm always interested in hearing about new projects and<br />
            opportunities. Whether you have a detailed brief or just<br />
            a rough idea, let's start a conversation.
          </p>

          <div class="space-y-5">
            <!-- Email -->
            <a href="mailto:johndavid.calimpong@gmail.com" class="flex items-center gap-3 text-sm hover:opacity-70 transition-opacity">
              <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" /></svg>
              johndavid.calimpong@gmail.com
            </a>

            <!-- Phone -->
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z" /></svg>
              +63 956-279-0038
            </div>

            <!-- Location -->
            <div class="flex items-center gap-3 text-sm">
              <svg class="w-5 h-5 text-neutral-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>
              Cebu City, PH
            </div>
          </div>
        </div>

        <!-- Right: Form -->
        <div>
          <form id="contact-form" class="space-y-6" action="https://formsubmit.co/johndavid.calimpong@gmail.com" method="POST">
            <input type="text" name="_honey" style="display:none" />
            <input type="hidden" name="_captcha" value="false" />
            <input type="hidden" name="_next" value="https://johndavid-portfolio.netlify.app/#contact" />

            <!-- Name -->
            <div>
              <label for="name" class="block text-xs uppercase tracking-wider text-neutral-500 mb-2">Name</label>
              <input
                type="text"
                id="name"
                name="name"
                placeholder="John Doe"
                required
                class="w-full bg-transparent border border-neutral-400 dark:border-neutral-600 text-brand-black dark:text-brand-bg text-sm px-4 py-3 placeholder-neutral-400 focus:outline-none focus:border-black dark:focus:border-white transition-colors"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="email" class="block text-xs uppercase tracking-wider text-neutral-500 mb-2">Email</label>
              <input
                type="email"
                id="email"
                name="email"
                placeholder="john@example.com"
                required
                class="w-full bg-transparent border border-neutral-400 dark:border-neutral-600 text-brand-black dark:text-brand-bg text-sm px-4 py-3 placeholder-neutral-400 focus:outline-none focus:border-black dark:focus:border-white transition-colors"
              />
            </div>

            <!-- Message -->
            <div>
              <label for="message" class="block text-xs uppercase tracking-wider text-neutral-500 mb-2">Message</label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="Tell me about your project..."
                required
                class="w-full bg-transparent border border-neutral-400 dark:border-neutral-600 text-brand-black dark:text-brand-bg text-sm px-4 py-3 placeholder-neutral-400 focus:outline-none focus:border-black dark:focus:border-white transition-colors resize-none"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-black dark:bg-brand-bg text-brand-bg dark:text-brand-black font-semibold text-sm uppercase tracking-wider py-4 hover:opacity-80 transition-opacity"
            >
              Send Message
            </button>
          </form>
        </div>

      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-t border-neutral-300 dark:border-neutral-700 max-w-6xl mx-auto px-4 md:px-8 py-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-neutral-600 dark:text-neutral-400">
    <p class="leading-none font-sans">© 2025 John David. All rights reserved.</p>

    <div class="flex items-center gap-2">
      <span>Built with</span>
      <span class="font-semibold text-black dark:text-brand-bg">Astro + Tailwind</span>
    </div>
  </div>
</footer>

<!-- Back to top -->
<button
  id="back-to-top"
  class="fixed right-6 bottom-6 w-10 h-10 bg-black dark:bg-brand-bg text-brand-bg dark:text-brand-black flex items-center justify-center text-xs font-mono opacity-0 pointer-events-none transition-all duration-300 hover:-translate-y-1 z-50"
  aria-label="Back to top"
>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7" /></svg>
</button>

<script>
  const backToTop = document.getElementById('back-to-top');
  if (backToTop) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 400) {
        backToTop.classList.remove('opacity-0', 'pointer-events-none');
        backToTop.classList.add('opacity-100', 'pointer-events-auto');
      } else {
        backToTop.classList.add('opacity-0', 'pointer-events-none');
        backToTop.classList.remove('opacity-100', 'pointer-events-auto');
      }
    }, { passive: true });

    backToTop.addEventListener('click', () => {
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
  }
</script>
