---
const projects = [
  {
    title: "CapstoneConnect",
    subtitle: "Team Formation with AI",
    description:
      "A smart system that uses AI to put students into capstone project teams. It pairs them based on technical skills, project interests, and compatibility.",
    fullDescription:
      "A smart system that uses AI to put students into capstone project teams. It pairs them based on technical skills, project interests, and compatibility. It finds good matches by understanding the meaning of their information and gives automatic team ideas.",
    image: "/images/capstoneconnect.JPG",
    role: "Frontend Developer and UI/UX Designer",
    stack: ["JavaScript", "CSS", "Figma"],
    contributions: [
      "Designed and prototyped the full user survey flow in Figma.",
      "Developed wireframes for the View Personality Modal and AI Card Matches display.",
      "Implemented the complete user survey form logic on the frontend using JavaScript.",
      "Implemented the final UI for the View Personality Modal and AI Card Matches.",
      "Ensured all components have responsive design across devices.",
    ],
    deployUrl: "https://capstoneconnect.netlify.app/",
  },
  {
    title: "Cartella",
    subtitle: "E-commerce Web Application",
    description:
      "A modern e-commerce platform connecting buyers and sellers with a user-friendly interface for browsing products, filtering options, and secure shopping.",
    fullDescription:
      "A modern e-commerce platform that connects buyers and sellers. It offers a user-friendly interface for browsing products, filtering options, and secure shopping.",
    image: "/images/cartella.JPG",
    role: "Frontend Developer and UI/UX Designer",
    stack: ["ReactJS", "Figma", "MUI (Material-UI)", "Canva"],
    contributions: [
      "Designed and prototyped the complete dual-sided (Vendor and Buyer) e-commerce platform flow in Figma.",
      "Created the platform logo using Canva.",
      "Implemented the entire application frontend using ReactJS.",
      "Utilized MUI components to build a consistent and modern UI.",
      "Developed with a focus on responsive design across all device sizes.",
    ],
    deployUrl: "https://cartellag5.netlify.app/",
  },
  {
    title: "FitTrack",
    subtitle: "Social Gym & Workout Logger",
    description:
      "A modern gym membership platform that allows users to log workouts, set fitness goals, and interact with others through social posts.",
    fullDescription:
      "FitTrack is a modern gym membership platform that allows users to log workouts, set and track fitness goals, and interact with others through social posts. Members can view workout history, post updates, and manage their fitness journey.",
    image: "/images/fittrack.JPG",
    role: "Frontend Developer and UI/UX Designer",
    stack: ["ReactJS", "CSS", "Figma", "Java"],
    contributions: [
      "Designed the wireframes in Figma for the View Post, Like, and Comment social features.",
      "Implemented the entire social feature frontend using ReactJS and CSS.",
      "Ensured the social features have fully responsive design across all devices.",
    ],
    videoUrl: "/video/fittrack.mp4",
  },
];
---

<section id="projects" class="w-full max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24">
  <div class="flex items-center justify-between mb-12">
    <div>
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-2">[04] Work</span>
      <h2 class="font-oswald text-5xl md:text-7xl uppercase tracking-tight">Projects</h2>
    </div>
    <span class="text-sm text-neutral-500 hidden md:block">{projects.length} PROJECTS</span>
  </div>

  <!-- Projects List -->
  <div class="space-y-0">
    {projects.map((project, index) => (
      <article
        class="project-item group relative border-t border-neutral-300 py-8 md:py-10 cursor-crosshair hover:bg-black/[0.02] transition-colors px-4 -mx-4"
        data-project-index={index}
      >
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4 md:gap-8 items-center relative z-10">
          <!-- Number -->
          <div class="md:col-span-1 text-neutral-400 text-sm font-mono">
            0{index + 1}
          </div>

          <!-- Title -->
          <div class="md:col-span-4">
            <h3 class="font-oswald text-2xl md:text-3xl uppercase tracking-tight group-hover:italic transition-none">
              {project.title}
            </h3>
            <p class="text-xs text-neutral-500 mt-1 uppercase tracking-wider">{project.subtitle}</p>
          </div>

          <!-- Description -->
          <div class="md:col-span-4">
            <p class="text-xs md:text-sm text-neutral-600 leading-relaxed">
              {project.description}
            </p>
          </div>

          <!-- Stack + Arrow -->
          <div class="md:col-span-3 flex items-center justify-between">
            <div class="flex flex-wrap gap-1.5">
              {project.stack.slice(0, 3).map((tech) => (
                <span class="text-[10px] uppercase border border-neutral-300 px-2 py-0.5">
                  {tech}
                </span>
              ))}
            </div>
            <svg class="w-5 h-5 text-neutral-400 group-hover:text-black group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
            </svg>
          </div>
        </div>

        <!-- Hover image overlay - appears on top of the row, overlapping the title -->
        <div class="pointer-events-none absolute inset-0 flex items-center justify-center z-20 opacity-0 group-hover:opacity-100 transition-all duration-500 ease-out">
          <img
            src={project.image}
            alt={project.title}
            class="w-[55%] max-w-md aspect-video object-cover shadow-2xl scale-90 group-hover:scale-100 transition-transform duration-500 ease-out border border-neutral-200"
          />
        </div>
      </article>
    ))}
    <!-- Bottom border -->
    <div class="border-t border-neutral-300"></div>
  </div>
</section>

<!-- Project Modal -->
<div id="project-modal" class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm opacity-0 invisible pointer-events-none">
  <div class="modal-dialog bg-brand-bg border border-neutral-300 w-full max-w-3xl max-h-[90vh] overflow-y-auto p-6 md:p-10 relative transform translate-y-6 opacity-0">
    <button id="modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center hover:bg-black hover:text-brand-bg transition-colors text-sm font-mono">
      [X]
    </button>

    <div id="modal-content">
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-2" id="modal-number"></span>
      <h3 class="font-oswald text-3xl md:text-4xl uppercase tracking-tight mb-1" id="modal-title"></h3>
      <p class="text-xs uppercase tracking-wider text-neutral-500 mb-6" id="modal-subtitle"></p>

      <div class="flex flex-wrap gap-2 mb-6" id="modal-stack"></div>

      <p class="text-sm leading-relaxed text-neutral-700 mb-8" id="modal-description"></p>

      <div class="mb-8 border border-neutral-200 overflow-hidden" id="modal-media"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div>
          <h4 class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 mb-3 border-l-2 border-black pl-3">Role</h4>
          <p class="text-sm" id="modal-role"></p>
        </div>
        <div>
          <h4 class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 mb-3 border-l-2 border-black pl-3">Key Contributions</h4>
          <ul class="text-sm space-y-2 list-disc list-inside text-neutral-700" id="modal-contributions"></ul>
        </div>
      </div>

      <div class="mt-8 flex gap-4" id="modal-actions"></div>
    </div>
  </div>
</div>

<!-- LinkedIn Modal -->
<div id="linkedin-modal" class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm opacity-0 invisible pointer-events-none">
  <div class="modal-dialog bg-brand-bg border border-neutral-300 w-full max-w-md p-6 md:p-8 relative transform translate-y-6 opacity-0">
    <button id="linkedin-modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center hover:bg-black hover:text-brand-bg transition-colors text-sm font-mono">
      [X]
    </button>
    <h3 class="font-oswald text-2xl uppercase tracking-tight mb-4">LinkedIn Account</h3>
    <p class="text-sm leading-relaxed text-neutral-700">
      My LinkedIn account is currently restricted and requires a valid ID verification.
      I'm currently processing the verification, and it will be available soon.
      Thank you for your understanding!
    </p>
  </div>
</div>

<script define:vars={{ projects }}>
  const modal = document.getElementById('project-modal');
  const modalDialog = modal?.querySelector('.modal-dialog');
  const modalClose = document.getElementById('modal-close');
  const projectItems = document.querySelectorAll('.project-item');

  function openModal(index) {
    const project = projects[index];
    if (!project || !modal) return;

    document.getElementById('modal-number').textContent = `[0${index + 1}]`;
    document.getElementById('modal-title').textContent = project.title;
    document.getElementById('modal-subtitle').textContent = project.subtitle;
    document.getElementById('modal-description').textContent = project.fullDescription;
    document.getElementById('modal-role').textContent = project.role;

    const stackEl = document.getElementById('modal-stack');
    stackEl.innerHTML = '';
    project.stack.forEach(tech => {
      const span = document.createElement('span');
      span.className = 'text-[10px] uppercase border border-neutral-300 px-3 py-1';
      span.textContent = tech;
      stackEl.appendChild(span);
    });

    const contribEl = document.getElementById('modal-contributions');
    contribEl.innerHTML = '';
    project.contributions.forEach(item => {
      const li = document.createElement('li');
      li.textContent = item;
      contribEl.appendChild(li);
    });

    const mediaEl = document.getElementById('modal-media');
    mediaEl.innerHTML = '';
    if (project.videoUrl) {
      const video = document.createElement('video');
      video.src = project.videoUrl;
      video.poster = project.image;
      video.controls = true;
      video.playsInline = true;
      video.className = 'w-full aspect-video object-cover';
      mediaEl.appendChild(video);
    } else {
      const img = document.createElement('img');
      img.src = project.image;
      img.alt = project.title;
      img.className = 'w-full aspect-video object-cover';
      mediaEl.appendChild(img);
    }

    const actionsEl = document.getElementById('modal-actions');
    actionsEl.innerHTML = '';
    if (project.deployUrl) {
      const a = document.createElement('a');
      a.href = project.deployUrl;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className = 'inline-flex items-center gap-2 px-6 py-3 bg-black text-brand-bg text-xs uppercase tracking-wider font-medium hover:opacity-80 transition-opacity';
      a.textContent = 'View Live Project';
      actionsEl.appendChild(a);
    }

    modal.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    modal.classList.add('opacity-100', 'visible', 'pointer-events-auto');
    modalDialog.classList.remove('translate-y-6', 'opacity-0');
    modalDialog.classList.add('translate-y-0', 'opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal || !modalDialog) return;
    modal.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    modal.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
    modalDialog.classList.add('translate-y-6', 'opacity-0');
    modalDialog.classList.remove('translate-y-0', 'opacity-100');
    document.body.style.overflow = '';
  }

  projectItems.forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.getAttribute('data-project-index'));
      openModal(index);
    });
  });

  modalClose?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // LinkedIn modal
  const linkedinModal = document.getElementById('linkedin-modal');
  const linkedinDialog = linkedinModal?.querySelector('.modal-dialog');
  const linkedinClose = document.getElementById('linkedin-modal-close');

  window.openLinkedInModal = function() {
    if (!linkedinModal || !linkedinDialog) return;
    linkedinModal.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    linkedinModal.classList.add('opacity-100', 'visible', 'pointer-events-auto');
    linkedinDialog.classList.remove('translate-y-6', 'opacity-0');
    linkedinDialog.classList.add('translate-y-0', 'opacity-100');
    document.body.style.overflow = 'hidden';
  };

  function closeLinkedInModal() {
    if (!linkedinModal || !linkedinDialog) return;
    linkedinModal.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    linkedinModal.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
    linkedinDialog.classList.add('translate-y-6', 'opacity-0');
    linkedinDialog.classList.remove('translate-y-0', 'opacity-100');
    document.body.style.overflow = '';
  }

  linkedinClose?.addEventListener('click', closeLinkedInModal);
  linkedinModal?.addEventListener('click', (e) => {
    if (e.target === linkedinModal) closeLinkedInModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLinkedInModal();
  });
</script>
