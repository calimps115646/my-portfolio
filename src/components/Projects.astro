---
const projects = [
  {
    title: "Skief Labs",
    year: "2026",
    fullDescription: "",
    image: "",
    role: "",
    stack: [],
    contributions: [],
    placeholder: true,
  },
  {
    title: "VetPulse",
    year: "2026",
    fullDescription: "",
    image: "",
    role: "",
    stack: [],
    contributions: [],
    placeholder: true,
  },
  {
    title: "CapstoneConnect",
    subtitle: "Team Formation with AI",
    year: "2025",
    fullDescription:
      "A smart system that uses AI to put students into capstone project teams. It pairs them based on technical skills, project interests, and compatibility. It finds good matches by understanding the meaning of their information and gives automatic team ideas.",
    image: "/images/capstoneconnect.JPG",
    role: "Frontend Developer and UI/UX Designer",
    stack: ["JavaScript", "CSS", "Figma"],
    contributions: [
      "Designed and prototyped the full user survey flow in Figma.",
      "Developed wireframes for the View Personality Modal and AI Card Matches display.",
      "Implemented the complete user survey form logic on the frontend using JavaScript.",
      "Implemented the final UI for the View Personality Modal and AI Card Matches.",
      "Ensured all components have responsive design across devices.",
    ],
    deployUrl: "https://capstoneconnect.netlify.app/",
  },
  {
    title: "Cartella",
    subtitle: "E-commerce Web Application",
    year: "2025",
    fullDescription:
      "A modern e-commerce platform that connects buyers and sellers. It offers a user-friendly interface for browsing products, filtering options, and secure shopping.",
    image: "/images/cartella.JPG",
    role: "Frontend Developer and UI/UX Designer",
    stack: ["ReactJS", "Figma", "MUI (Material-UI)", "Canva"],
    contributions: [
      "Designed and prototyped the complete dual-sided (Vendor and Buyer) e-commerce platform flow in Figma.",
      "Created the platform logo using Canva.",
      "Implemented the entire application frontend using ReactJS.",
      "Utilized MUI components to build a consistent and modern UI.",
      "Developed with a focus on responsive design across all device sizes.",
    ],
    deployUrl: "https://cartellag5.netlify.app/",
  },
];
---

<section id="projects" class="w-full max-w-6xl mx-auto px-4 md:px-8 py-16 md:py-24">
  <div class="flex items-center justify-between mb-12">
    <div>
      <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-2">[03] Work</span>
      <h2 class="font-oswald text-5xl md:text-7xl uppercase tracking-tight">Projects</h2>
    </div>
    <span class="text-sm text-neutral-500 hidden md:block">{projects.length} PROJECTS</span>
  </div>

  <!-- Projects List -->
  <div class="space-y-0">
    {projects.map((project, index) => (
      <article
        class={`group relative border-t border-neutral-300 dark:border-neutral-700 py-12 md:py-16 cursor-crosshair transition-colors ${project.placeholder ? 'opacity-40' : 'project-item'}`}
        data-project-index={project.placeholder ? undefined : index}
      >
        <div class={`flex items-center relative z-20 px-4 md:px-8 ${!project.placeholder ? 'group-hover:mix-blend-difference' : ''}`}>
          <!-- Number -->
          <span class={`text-sm font-mono transition-colors duration-500 shrink-0 w-12 ${!project.placeholder ? 'text-neutral-400 group-hover:text-white/60' : 'text-neutral-400'}`}>0{index + 1}</span>

          <!-- Title -->
          <h3 class={`font-oswald text-5xl md:text-7xl lg:text-8xl uppercase tracking-tight transition-all duration-500 flex-1 ${!project.placeholder ? 'group-hover:text-white group-hover:translate-x-4' : ''}`}>
            {project.title}
          </h3>

          <!-- Year + Arrow -->
          <div class="flex items-center gap-3 shrink-0 relative z-30">
            {project.year && (
              <span class={`text-sm border border-neutral-400 dark:border-neutral-600 px-3 py-1 transition-colors duration-500 ${!project.placeholder ? 'group-hover:text-white group-hover:border-white/40' : ''}`}>
                {project.year}
              </span>
            )}
            {!project.placeholder && (
              <svg class="w-5 h-5 text-neutral-400 group-hover:text-white group-hover:translate-x-1 transition-all duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 17L17 7M17 7H7M17 7v10" />
              </svg>
            )}
          </div>
        </div>

        {!project.placeholder && project.image && (
          <div
            class="hidden md:block absolute opacity-0 group-hover:opacity-100 transition-all duration-500 z-10 pointer-events-none overflow-hidden border border-neutral-300 dark:border-neutral-700"
            style={`width: 520px; height: 260px; top: 50%; right: 15%; transform: translateY(-50%) scale(0.95) rotate(0deg); transition: opacity 0.5s, transform 0.5s;`}
            data-hover-transform={`translateY(-50%) scale(1.05) rotate(${index % 2 === 0 ? '-3' : '3'}deg)`}
            data-default-transform="translateY(-50%) scale(0.95) rotate(0deg)"
          >
            <img
              src={project.image}
              alt={project.title}
              class="w-full h-full object-contain grayscale group-hover:grayscale-0 transition-all duration-700"
            />
          </div>
        )}
      </article>
    ))}
    <!-- Bottom border -->
    <div class="border-t border-neutral-300 dark:border-neutral-700"></div>
  </div>
</section>

<!-- Project Modal -->
<div id="project-modal" class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm opacity-0 invisible pointer-events-none">
  <div class="modal-dialog bg-brand-bg dark:bg-brand-black border border-neutral-300 dark:border-neutral-700 w-full max-w-3xl max-h-[90vh] overflow-y-auto relative transform translate-y-6 opacity-0">
    <!-- Header -->
    <div class="p-6 pb-0">
      <div class="flex items-start justify-between">
        <div>
          <span class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 block mb-2" id="modal-number"></span>
          <h3 class="font-oswald text-2xl md:text-3xl uppercase tracking-tight mb-1" id="modal-title"></h3>
          <p class="text-xs uppercase tracking-wider text-neutral-500" id="modal-subtitle"></p>
        </div>
        <button id="modal-close" class="w-8 h-8 flex items-center justify-center hover:bg-black hover:text-brand-bg dark:hover:bg-brand-bg dark:hover:text-brand-black transition-colors text-sm font-mono shrink-0">
          [X]
        </button>
      </div>
    </div>

    <div id="modal-content" class="p-6">
      <!-- Tech Stack -->
      <div class="flex flex-wrap gap-2 mb-4" id="modal-stack"></div>

      <!-- Description -->
      <p class="text-sm leading-relaxed text-neutral-700 dark:text-neutral-300 mb-6" id="modal-description"></p>

      <!-- Media -->
      <div class="mb-6 border border-neutral-200 dark:border-neutral-700 overflow-hidden" id="modal-media"></div>

      <!-- Role -->
      <div class="mb-6">
        <h4 class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 mb-3 border-l-2 border-black dark:border-brand-bg pl-3">Role</h4>
        <p class="text-sm" id="modal-role"></p>
      </div>

      <!-- Key Contributions -->
      <div class="mb-6">
        <h4 class="text-[10px] uppercase tracking-[0.3em] text-neutral-500 mb-3 border-l-2 border-black dark:border-brand-bg pl-3">Key Contributions</h4>
        <ul class="text-sm space-y-2 text-neutral-700 dark:text-neutral-300" id="modal-contributions"></ul>
      </div>

      <!-- Actions -->
      <div class="flex justify-center" id="modal-actions"></div>
    </div>
  </div>
</div>

<!-- LinkedIn Modal -->
<div id="linkedin-modal" class="modal-overlay fixed inset-0 z-[100] flex items-center justify-center p-4 bg-black/40 backdrop-blur-sm opacity-0 invisible pointer-events-none">
  <div class="modal-dialog bg-brand-bg dark:bg-brand-black border border-neutral-300 dark:border-neutral-700 w-full max-w-md p-6 md:p-8 relative transform translate-y-6 opacity-0">
    <button id="linkedin-modal-close" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center hover:bg-black hover:text-brand-bg dark:hover:bg-brand-bg dark:hover:text-brand-black transition-colors text-sm font-mono">
      [X]
    </button>
    <h3 class="font-oswald text-2xl uppercase tracking-tight mb-4">LinkedIn Account</h3>
    <p class="text-sm leading-relaxed text-neutral-700 dark:text-neutral-300">
      My LinkedIn account is currently restricted and requires a valid ID verification.
      I'm currently processing the verification, and it will be available soon.
      Thank you for your understanding!
    </p>
  </div>
</div>

<script define:vars={{ projects }}>
  const modal = document.getElementById('project-modal');
  const modalDialog = modal?.querySelector('.modal-dialog');
  const modalClose = document.getElementById('modal-close');
  const projectItems = document.querySelectorAll('.project-item');

  function openModal(index) {
    const project = projects[index];
    if (!project || !modal) return;

    document.getElementById('modal-number').textContent = `[0${index + 1}]`;
    document.getElementById('modal-title').textContent = project.title;
    document.getElementById('modal-subtitle').textContent = project.subtitle;
    document.getElementById('modal-description').textContent = project.fullDescription;
    document.getElementById('modal-role').textContent = project.role;

    const stackEl = document.getElementById('modal-stack');
    stackEl.innerHTML = '';
    project.stack.forEach(tech => {
      const span = document.createElement('span');
      span.className = 'text-[10px] uppercase border border-neutral-300 dark:border-neutral-600 px-3 py-1';
      span.textContent = tech;
      stackEl.appendChild(span);
    });

    const contribEl = document.getElementById('modal-contributions');
    contribEl.innerHTML = '';
    project.contributions.forEach(item => {
      const li = document.createElement('li');
      li.className = 'flex gap-2';
      li.innerHTML = `<span class="shrink-0">•</span><span>${item}</span>`;
      contribEl.appendChild(li);
    });

    const mediaEl = document.getElementById('modal-media');
    mediaEl.innerHTML = '';
    if (project.videoUrl) {
      const video = document.createElement('video');
      video.src = project.videoUrl;
      video.poster = project.image;
      video.controls = true;
      video.playsInline = true;
      video.className = 'w-full aspect-video object-cover';
      mediaEl.appendChild(video);
    } else {
      const img = document.createElement('img');
      img.src = project.image;
      img.alt = project.title;
      img.className = 'w-full aspect-video object-contain';
      mediaEl.appendChild(img);
    }

    const actionsEl = document.getElementById('modal-actions');
    actionsEl.innerHTML = '';
    if (project.deployUrl) {
      const a = document.createElement('a');
      a.href = project.deployUrl;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className = 'inline-flex items-center gap-2 px-6 py-3 bg-black dark:bg-brand-bg text-brand-bg dark:text-brand-black text-xs uppercase tracking-wider font-medium hover:opacity-80 transition-opacity';
      a.textContent = 'View Live Project';
      actionsEl.appendChild(a);
    }

    modal.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    modal.classList.add('opacity-100', 'visible', 'pointer-events-auto');
    modalDialog.classList.remove('translate-y-6', 'opacity-0');
    modalDialog.classList.add('translate-y-0', 'opacity-100');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!modal || !modalDialog) return;
    modal.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    modal.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
    modalDialog.classList.add('translate-y-6', 'opacity-0');
    modalDialog.classList.remove('translate-y-0', 'opacity-100');
    document.body.style.overflow = '';
  }

  projectItems.forEach(item => {
    item.addEventListener('click', () => {
      const index = parseInt(item.getAttribute('data-project-index'));
      openModal(index);
    });
  });

  modalClose?.addEventListener('click', closeModal);

  // LinkedIn modal
  const linkedinModal = document.getElementById('linkedin-modal');
  const linkedinDialog = linkedinModal?.querySelector('.modal-dialog');
  const linkedinClose = document.getElementById('linkedin-modal-close');

  window.openLinkedInModal = function() {
    if (!linkedinModal || !linkedinDialog) return;
    linkedinModal.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    linkedinModal.classList.add('opacity-100', 'visible', 'pointer-events-auto');
    linkedinDialog.classList.remove('translate-y-6', 'opacity-0');
    linkedinDialog.classList.add('translate-y-0', 'opacity-100');
    document.body.style.overflow = 'hidden';
  };

  function closeLinkedInModal() {
    if (!linkedinModal || !linkedinDialog) return;
    linkedinModal.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    linkedinModal.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
    linkedinDialog.classList.add('translate-y-6', 'opacity-0');
    linkedinDialog.classList.remove('translate-y-0', 'opacity-100');
    document.body.style.overflow = '';
  }

  linkedinClose?.addEventListener('click', closeLinkedInModal);

  // Project image hover transforms
  document.querySelectorAll('.project-item').forEach(item => {
    const imgContainer = item.querySelector('[data-hover-transform]');
    if (!imgContainer) return;

    const hoverTransform = imgContainer.getAttribute('data-hover-transform');
    const defaultTransform = imgContainer.getAttribute('data-default-transform');

    item.addEventListener('mouseenter', () => {
      imgContainer.style.transform = hoverTransform;
    });
    item.addEventListener('mouseleave', () => {
      imgContainer.style.transform = defaultTransform;
    });
  });
</script>
