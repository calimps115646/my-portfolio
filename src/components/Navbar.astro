---
---

<!-- INITIAL NAVBAR (visible at top) -->
<nav id="nav-full" class="w-full px-4 py-6 md:px-8 md:py-8 flex justify-between items-start text-xs md:text-sm font-medium relative z-40 transition-all duration-500">
  <!-- Logo -->
  <a href="/" class="flex flex-col leading-none tracking-tight group cursor-pointer">
    <span class="group-hover:translate-x-1 transition-transform duration-300">JOHN</span>
    <span class="font-bold group-hover:translate-x-1 transition-transform duration-300 delay-75">DAVID.</span>
  </a>

  <!-- Center Links -->
  <div class="hidden md:flex gap-12 absolute left-1/2 -translate-x-1/2 top-8">
    <a href="#about" class="group relative overflow-hidden">
      <span class="group-hover:-translate-y-full block transition-transform duration-300">[ABOUT ME]</span>
      <span class="absolute top-0 left-0 translate-y-full group-hover:translate-y-0 block transition-transform duration-300 text-neutral-500">[ABOUT ME]</span>
    </a>
    <a href="#projects" class="group relative overflow-hidden">
      <span class="group-hover:-translate-y-full block transition-transform duration-300">[PROJECTS]</span>
      <span class="absolute top-0 left-0 translate-y-full group-hover:translate-y-0 block transition-transform duration-300 text-neutral-500">[PROJECTS]</span>
    </a>
    <a href="#contact" class="group relative overflow-hidden">
      <span class="group-hover:-translate-y-full block transition-transform duration-300">[CONTACT]</span>
      <span class="absolute top-0 left-0 translate-y-full group-hover:translate-y-0 block transition-transform duration-300 text-neutral-500">[CONTACT]</span>
    </a>
  </div>

  <!-- Right: Theme Toggle -->
  <button
    id="theme-toggle"
    class="flex items-center gap-2 text-xs md:text-sm font-medium hover:text-neutral-500 transition-colors"
    aria-label="Toggle theme"
  >
    <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
    <svg id="moon-icon" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
    <span id="theme-label">[DARK MODE]</span>
  </button>
</nav>

<!-- COMPACT NAVBAR (appears on scroll) -->
<div id="nav-compact" class="hidden md:block fixed left-1/2 z-50 pointer-events-none" style="top: 1rem; transform: translateX(-50%) translateY(-150%); transition: transform 0.5s cubic-bezier(0.16,1,0.3,1);">
  <div class="flex items-center gap-6 px-6 py-3 border border-neutral-400 dark:border-neutral-600 bg-brand-bg/35 dark:bg-brand-black/35 backdrop-blur-xl text-xs font-medium text-brand-black dark:text-brand-bg transition-none">
    <!-- Name (scroll to top) -->
    <a href="#" id="compact-logo" class="tracking-tight whitespace-nowrap cursor-pointer hover:text-neutral-500 transition-none">JOHN <span class="font-bold">DAVID.</span></a>

    <!-- Divider -->
    <span class="w-px h-4 bg-neutral-500 dark:bg-neutral-500"></span>

    <!-- Links -->
    <div class="flex items-center gap-6">
      <a href="#about" class="hover:text-neutral-500 transition-none">[ABOUT ME]</a>
      <a href="#projects" class="hover:text-neutral-500 transition-none">[PROJECTS]</a>
      <a href="#contact" class="hover:text-neutral-500 transition-none">[CONTACT]</a>
    </div>

    <!-- Divider -->
    <span class="w-px h-4 bg-neutral-500 dark:bg-neutral-500"></span>

    <!-- Theme Toggle (icon only) -->
    <button id="theme-toggle-compact" class="hover:text-neutral-500 transition-colors" aria-label="Toggle theme">
      <svg id="sun-icon-compact" class="w-4 h-4 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>
      <svg id="moon-icon-compact" class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
    </button>
  </div>
</div>

<!-- Mobile Menu Button -->
<button
  id="mobile-menu-btn"
  class="md:hidden fixed top-6 left-1/2 -translate-x-1/2 z-50 px-4 py-2 bg-black dark:bg-brand-bg text-brand-bg dark:text-brand-black text-xs font-medium tracking-wider rounded-full"
>
  [MENU]
</button>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu" class="fixed inset-0 bg-brand-bg dark:bg-brand-black z-[60] flex flex-col items-center justify-center gap-8 text-2xl font-medium opacity-0 invisible transition-all duration-300 pointer-events-none">
  <button id="mobile-menu-close" class="absolute top-6 right-6 text-sm">[CLOSE]</button>
  <a href="#about" class="mobile-nav-link hover:text-neutral-500 transition-colors">[ABOUT ME]</a>
  <a href="#projects" class="mobile-nav-link hover:text-neutral-500 transition-colors">[PROJECTS]</a>
  <a href="#contact" class="mobile-nav-link hover:text-neutral-500 transition-colors">[CONTACT]</a>
</div>

<script>
  // Mobile menu
  const menuBtn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuClose = document.getElementById('mobile-menu-close');

  menuBtn?.addEventListener('click', () => {
    menu?.classList.remove('opacity-0', 'invisible', 'pointer-events-none');
    menu?.classList.add('opacity-100', 'visible', 'pointer-events-auto');
  });

  const closeMenu = () => {
    menu?.classList.add('opacity-0', 'invisible', 'pointer-events-none');
    menu?.classList.remove('opacity-100', 'visible', 'pointer-events-auto');
  };

  menuClose?.addEventListener('click', closeMenu);
  document.querySelectorAll('.mobile-nav-link').forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  const themeToggleCompact = document.getElementById('theme-toggle-compact');
  const sunIcon = document.getElementById('sun-icon');
  const moonIcon = document.getElementById('moon-icon');
  const sunIconCompact = document.getElementById('sun-icon-compact');
  const moonIconCompact = document.getElementById('moon-icon-compact');
  const themeLabel = document.getElementById('theme-label');

  function updateIcons() {
    const isDark = document.documentElement.classList.contains('dark');
    sunIcon?.classList.toggle('hidden', !isDark);
    moonIcon?.classList.toggle('hidden', isDark);
    sunIconCompact?.classList.toggle('hidden', !isDark);
    moonIconCompact?.classList.toggle('hidden', isDark);
    if (themeLabel) themeLabel.textContent = isDark ? '[LIGHT MODE]' : '[DARK MODE]';
  }

  updateIcons();

  function toggleTheme() {
    document.documentElement.classList.toggle('dark');
    const isDark = document.documentElement.classList.contains('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
    updateIcons();
  }

  themeToggle?.addEventListener('click', toggleTheme);
  themeToggleCompact?.addEventListener('click', toggleTheme);

  // Compact logo: smooth scroll to top
  document.getElementById('compact-logo')?.addEventListener('click', (e) => {
    e.preventDefault();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });

  // Scroll-based navbar switch
  const navFull = document.getElementById('nav-full');
  const navCompact = document.getElementById('nav-compact');
  let isCompact = false;

  window.addEventListener('scroll', () => {
    const scrollY = window.scrollY;

    if (scrollY > 100 && !isCompact) {
      isCompact = true;
      navFull?.classList.add('opacity-0', 'pointer-events-none');
      if (navCompact) navCompact.style.transform = 'translateX(-50%) translateY(0)';
      navCompact?.classList.remove('pointer-events-none');
      navCompact?.classList.add('pointer-events-auto');
    } else if (scrollY <= 100 && isCompact) {
      isCompact = false;
      navFull?.classList.remove('opacity-0', 'pointer-events-none');
      if (navCompact) navCompact.style.transform = 'translateX(-50%) translateY(-150%)';
      navCompact?.classList.add('pointer-events-none');
      navCompact?.classList.remove('pointer-events-auto');
    }
  }, { passive: true });
</script>
